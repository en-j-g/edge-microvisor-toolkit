# This patch manually sets the golang version to a specific version defined in kubernetes dependencies.
# https://github.com/kubernetes/kubernetes/blob/v1.32.4/build/dependencies.yaml
--- scripts/version.sh
+++ scripts/version.sh
@@ -79,7 +79,7 @@
 VERSION_ROOT="v0.14.1"
 
 DEPENDENCIES_URL="https://raw.githubusercontent.com/kubernetes/kubernetes/${VERSION_K8S}/build/dependencies.yaml"
-VERSION_GOLANG="go"$(curl -sL "${DEPENDENCIES_URL}" | yq e '.dependencies[] | select(.name == "golang: upstream version").version' -)
+VERSION_GOLANG="go1.23.7"
 
 if [[ -n "$GIT_TAG" ]]; then
     if [[ ! "$GIT_TAG" =~ ^"$VERSION_K8S"[+-] ]]; then
